# Copy this file to .env and fill local-only values.

KASLANA_CONFIG_PATH=config/config.yaml
KASLANA_CONDA_ENV=kaslana-protocol

# Local TTS smoke-test defaults. Keep real model assets out of Git.
KASLANA_TTS_INFER_CONFIG=assets\琪亚娜E7\琪亚娜E7\infer_config.json
KASLANA_TTS_API_STYLE=gsvi
KASLANA_TTS_ENDPOINT=http://127.0.0.1:5100

# Adapter secrets should be read through env names configured in YAML.
KASLANA_LLM_API_KEY=replace-me
KASLANA_TTS_API_KEY=replace-me-if-needed
